(function () {
  'use strict';

  // CHANGE THIS AFTER RENDER DEPLOYMENT:
  const API_BASE = 'https://fries91-torn-profit-brain.onrender.com';

  const K_TOKEN = 'fries91_torn_brain_token_v1';
  const K_OPEN = 'fries91_torn_brain_open_v1';
