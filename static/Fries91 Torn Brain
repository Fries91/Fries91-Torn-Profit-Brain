    }
    #tb-panel:before {
      content: '';
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(rgba(34,197,94,.045) 1px, transparent 1px),
        linear-gradient(90deg, rgba(34,197,94,.045) 1px, transparent 1px);
      background-size: 38px 38px;
      pointer-events: none;
      animation: tbGridMove 8s linear infinite;
    }
