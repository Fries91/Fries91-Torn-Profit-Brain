  let state = null;
  let activeTab = 'Overview';
  let mounted = false;
  let refreshTimer = null;

  GM_addStyle(`
    @keyframes tbPulseGlow {
      0%, 100% { box-shadow: 0 0 10px rgba(34,197,94,.45), 0 0 24px rgba(250,204,21,.20), 0 8px 24px rgba(0,0,0,.70); transform: translateZ(0) scale(1); }
