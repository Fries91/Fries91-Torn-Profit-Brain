      max-width: 760px;
      margin: 0 auto;
      background:
        radial-gradient(circle at 10% 0%, rgba(34,197,94,.18), transparent 28%),
        radial-gradient(circle at 100% 10%, rgba(250,204,21,.12), transparent 30%),
