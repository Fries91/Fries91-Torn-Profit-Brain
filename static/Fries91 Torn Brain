      height: 42px;
      padding: 0 8px;
      border-radius: 15px;
      background:
        radial-gradient(circle at 20% 20%, rgba(34,197,94,.35), transparent 34%),
        linear-gradient(135deg, #07110b, #111827 45%, #2a1d08);
      border: 1px solid rgba(250,204,21,.88);
      color: #dcfce7;
      display: flex;
      align-items: center;
      justify-content: center;
